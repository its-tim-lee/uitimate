---
import "@/index.css"; // according to https://ui.shadcn.com/docs/installation/astro
import Welcome from "../components/Welcome.astro";
import Layout from "../layouts/BaseLayout.astro";
import RefTest from "../components/quick-test/RefTest.tsx";
import { TestAlert } from "../components/quick-test/TestAlert.tsx";
import { RadixSlot } from "../components/quick-test/RadixSlot.tsx";
import TailwindPeerStyling from "../components/quick-test/TailwindPeerStyling/index.tsx";
import DownloadHelper from "../components/quick-test/DownloadHelper.tsx";
import FetchComponent from "../components/quick-test/FetchComponent.tsx";
import OpenCodesandbox from "../components/quick-test/OpenCSB.tsx";
import DialogDropdownMenu from "../components/demo/dialog-dropdown-menu.tsx";
---

<Layout>
  <DialogDropdownMenu client:only="react" />
  <FetchComponent client:only="react" />
  <DownloadHelper client:only="react" />
  <OpenCodesandbox client:only="react" />
  <TailwindPeerStyling client:only="react" />
  <RadixSlot client:only="react" />

  <TestAlert
    title="Test2"
    description="!!!Test2"
    variant="destructive"
    icon="lucide:terminal"
    client:only="react"
  />
  <Welcome class="tw:p-4" />
</Layout>
