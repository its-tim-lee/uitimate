---
import { startCase } from "lodash-es";
import "@/index.css"; // according to https://ui.shadcn.com/docs/installation/astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import DocPageLayout from "@/layouts/DocPageLayout.astro";
import ComponentPageUsage from "@/components/internal/ComponentPageUsage.tsx";
import ComponentPageHero from "@/components/internal/ComponentPageHero.tsx";
import { Badge } from "@/components/ui/Badge/Badge";
import {
  Heading,
  HeadingSubtitle,
  HeadingTitle,
} from "@/components/ui/Heading/Heading";
import VersatileTabs from "@/components/internal/VersatileTabs";
const routeName = Astro.url.pathname.split("/").filter(Boolean).pop();
const anatomy = `
<Textarea/>
`;
const apiLink = `https://headlessui.com/react/textarea/${routeName}`;
---

<BaseLayout>
  <DocPageLayout>
    <ComponentPageHero
      client:only="react"
      apiLink={apiLink}
      title={startCase(routeName)}
      subtitle="A light wrapper around the native textarea element that handles tedious accessibility concerns and provides more opinionated states for things like hover and focus."
    />

    <br />

    <Heading
      size="h2"
      title="Usage"
      subtitle="How you can play this component."
    />
    <ComponentPageUsage
      demoId="textarea-demo"
      anatomy={anatomy}
      client:only="react"
      preview="This example forces the textarea being focused when rendered, and prevent user from resizing it vertically (ie. via Tailwind's `resize-none`)."
    />

    <br />
    <br />

    <Heading
      size="h2"
      title="Design Notes"
      subtitle="The implementation details that some would appreciate."
    />
    <p>
      The Textarea we provide here is only meant to be used in simple cases,
      because such component can be very complicated, especially the ones used
      in the chat applications, which is the type of components that are highly
      sophisticated that most of Textarea components provided by the UI
      libraries/frameworks can't not support well, in which case, you'd need to
      implement your own.
      <br />
      <br />
    </p>
  </DocPageLayout>
</BaseLayout>
