---
import { startCase } from "lodash-es";
import "@/index.css"; // according to https://ui.shadcn.com/docs/installation/astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import DocPageLayout from "@/layouts/DocPageLayout.astro";
import ComponentPageHero from "@/components/internal/ComponentPageHero.tsx";
import { Heading } from "@/components/ui/Heading/Heading";
import { Badge } from "~/src/components/ui/Badge/Badge";
import ComponentPageUsage from "@/components/internal/ComponentPageUsage.tsx";
const routeName = Astro.url.pathname.split("/").filter(Boolean).pop();
const apiLink = `https://github.com/Aljullu/react-lazy-load-image-component#readme`;
const anatomy = `<Image />`;
---

<BaseLayout>
  <DocPageLayout>
    <ComponentPageHero
      client:only="react"
      apiLink={apiLink}
      title={startCase(routeName)}
      subtitle="lazy load images."
    />

    <br />
    <br />

    <Heading
      size="h2"
      title="Usage"
      subtitle="How you can play this component."
    />
    <ComponentPageUsage
      demoId="image-demo"
      anatomy={anatomy}
      client:only="react"
      preview="We simply wrap react-lazy-load-image-component under the hood, so go check the corresponding doc. At the same time, if possible, I recommend you to use Cloudinary."
    />

    <br />
    <br />
  </DocPageLayout>
</BaseLayout>
