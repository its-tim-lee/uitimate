---
import { startCase } from "lodash-es";
import "@/index.css"; // according to https://ui.shadcn.com/docs/installation/astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import DocPageLayout from "@/layouts/DocPageLayout.astro";
import ComponentPageUsage from "@/components/internal/ComponentPageUsage.tsx";
import ComponentPageHero from "@/components/internal/ComponentPageHero.tsx";
import {
  Heading,
  HeadingSubtitle,
  HeadingTitle,
} from "~/src/components/ui/Heading/Heading";

const routeName = Astro.url.pathname.split("/").filter(Boolean).pop();
const anatomy = `<AspectRatio/>`;
---

<BaseLayout>
  <DocPageLayout>
    <!-- FIXME:
      once encapsulate Icon into tsx, we can't use client:only anymore, so
      we then need to make the entire component to be client:only
    -->
    <ComponentPageHero
      title={startCase(routeName)}
      subtitle="Displays content within a desired ratio."
      client:only="react"
    />

    <Heading size="h2">
      <HeadingTitle>Usage</HeadingTitle>
      <HeadingSubtitle>How you can play this component.</HeadingSubtitle>
    </Heading>

    <ComponentPageUsage
      demoId="aspect-ratio-demo"
      anatomy={anatomy}
      client:only="react"
    />

    <!-- ComponentPageAPI -->
  </DocPageLayout>
</BaseLayout>
