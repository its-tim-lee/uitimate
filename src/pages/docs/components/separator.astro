---
import { startCase } from "lodash-es";
import "@/index.css"; // according to https://ui.shadcn.com/docs/installation/astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import DocPageLayout from "@/layouts/DocPageLayout.astro";
import ComponentPageUsage from "@/components/internal/ComponentPageUsage.tsx";
import ComponentPageHero from "@/components/internal/ComponentPageHero.tsx";
import {
  Heading,
  HeadingSubtitle,
  HeadingTitle,
} from "@/components/ui/Heading/Heading";
import VersatileTabs from "@/components/internal/VersatileTabs";
import { Badge } from "~/src/components/ui/Badge/Badge";
const routeName = Astro.url.pathname.split("/").filter(Boolean).pop();
const anatomy = `<Separator/>`;
const apiLink = `https://www.radix-ui.com/primitives/docs/components/separator`;
---

<BaseLayout>
  <DocPageLayout>
    <ComponentPageHero
      apiLink={apiLink}
      title={startCase(routeName)}
      subtitle="Visually or semantically separates content."
    />

    <br />

    <Heading
      size="h2"
      title="Usage"
      subtitle="How you can play this component."
    />
    <ComponentPageUsage
      demoId="separator-demo"
      anatomy={anatomy}
      client:only="react"
      preview="In most of time, `orientation` is the only prop you need to care about (the default value for that is `horizontal`), but for more, check out the API reference."
    />

    <br />
    <br />

    <Heading
      size="h2"
      title="Example / Scenario"
      subtitle="This lists common real-world use cases."
    />
    <VersatileTabs
      settings={[
        {
          title: "Vertical",
          type: "preview",
          demoId: "separator-vertical",
        },
      ]}
      client:only="react"
    />
  </DocPageLayout>
</BaseLayout>
