---
import { startCase } from "lodash-es";
import "@/index.css"; // according to https://ui.shadcn.com/docs/installation/astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import DocPageLayout from "@/layouts/DocPageLayout.astro";
import ComponentPageUsage from "@/components/internal/ComponentPageUsage.tsx";
import ComponentPageHero from "@/components/internal/ComponentPageHero.tsx";
import {
  Heading,
  HeadingSubtitle,
  HeadingTitle,
} from "@/components/ui/Heading/Heading";
import VersatileTabs from "@/components/internal/VersatileTabs";
const routeName = Astro.url.pathname.split("/").filter(Boolean).pop();
const anatomy = `
<DropdownMenu>
  <DropdownMenuTrigger/>
  <DropdownMenuContent/>
</DropdownMenu>
`;
const apiLink = `https://www.radix-ui.com/primitives/docs/components/${routeName}`;
---

<BaseLayout>
  <DocPageLayout>
    <ComponentPageHero
      client:only="react"
      apiLink={apiLink}
      title={startCase(routeName)}
      subtitle="Displays a menu to the user—such as a set of actions or functions—triggered by a button."
    />

    <br />

    <Heading
      size="h2"
      title="Usage"
      subtitle="How you can play this component."
    />
    <ComponentPageUsage
      demoId="dropdownmenu-demo"
      anatomy={anatomy}
      client:only="react"
    />

    <br />
    <br />

    <Heading
      size="h2"
      title="Example / API"
      subtitle="This tries to show all the API/Component usages."
    />
    <VersatileTabs
      settings={[
        {
          title: "Mix",
          type: "preview",
          demoId: "dropdownmenu-mix1",
          content: "This represents almost all the APIs",
        },
        {
          title: "Radio + Checkbox",
          type: "preview",
          demoId: "dropdownmenu-mix2",
        },
      ]}
      client:only="react"
    />

    <!-- ComponentPageAPI -->
  </DocPageLayout>
</BaseLayout>
