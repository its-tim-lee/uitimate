---
import { startCase } from "lodash-es";
import "@/index.css"; // according to https://ui.shadcn.com/docs/installation/astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import DocPageLayout from "@/layouts/DocPageLayout.astro";
import ComponentPageUsage from "@/components/internal/ComponentPageUsage.tsx";
import ComponentPageHero from "@/components/internal/ComponentPageHero.tsx";
import {
  Heading,
  HeadingSubtitle,
  HeadingTitle,
} from "@/components/ui/Heading/Heading";
import VersatileTabs from "@/components/internal/VersatileTabs";
import { Badge } from "~/src/components/ui/Badge/Badge";
const routeName = Astro.url.pathname.split("/").filter(Boolean).pop();
const anatomy = `
<HoverCard>
  <HoverCardTrigger/>
  <HoverCardContent/>
`;
const apiLink = `https://www.radix-ui.com/primitives/docs/components/hover-card`;
---

<BaseLayout>
  <DocPageLayout>
    <ComponentPageHero
      client:only="react"
      apiLink={apiLink}
      title={startCase(routeName)}
      subtitle="For sighted users to preview content available behind a link."
    />

    <br />
    <br />
    <Heading
      size="h2"
      title="Usage"
      subtitle="How you can play this component."
    />
    <ComponentPageUsage
      demoId="hovercard-demo"
      anatomy={anatomy}
      client:only="react"
    />
    <br />
    <br />
    <Heading
      size="h2"
      title="Example / Scenario"
      subtitle="This lists common real-world use cases."
    />
    <VersatileTabs
      settings={[
        {
          title: "API DOC",
          type: "preview",
          demoId: "hovercard-api-doc",
          content:
            "(Note: this example comes from Electron doc) Many things are covered at this example: first, you can control the opening state of the HoverCard component, but what below really reveals is another way to use this component; As you can see we put a fake element span inside HoverCardTrigger, and this can be used for some people that don't want to do heavily composition, but now it'd have some caveats that needed to be handled maually, and you can try what'd happen if `sideOffset` and `align` are removed. ",
        },
      ]}
      client:only="react"
    />

    <br />
    <br />
  </DocPageLayout>
</BaseLayout>
