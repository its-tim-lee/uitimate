---
import { startCase } from "lodash-es";
import "@/index.css"; // according to https://ui.shadcn.com/docs/installation/astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import DocPageLayout from "@/layouts/DocPageLayout.astro";
import ComponentPageUsage from "@/components/internal/ComponentPageUsage.tsx";
import ComponentPageHero from "@/components/internal/ComponentPageHero.tsx";
import {
  Heading,
  HeadingSubtitle,
  HeadingTitle,
} from "@/components/ui/Heading/Heading";
import VersatileTabs from "@/components/internal/VersatileTabs";
const routeName = Astro.url.pathname.split("/").filter(Boolean).pop();
const anatomy = `
  <Heading>
    <HeadingTitle/>
    <HeadingSubtitle/>
  </Heading>
`;
---

<BaseLayout>
  <DocPageLayout>
    <ComponentPageHero
      client:only="react"
      title={startCase(routeName)}
      subtitle="A primitive that contains a title and an optional subtitle."
    />

    <br />

    <Heading
      size="h2"
      title="Usage"
      subtitle="How you can play this component."
    />
    <ComponentPageUsage
      demoId="heading-demo"
      anatomy={anatomy}
      client:only="react"
    />

    <br />
    <br />

    <Heading
      size="h2"
      title="Design Notes"
      subtitle="The implementation details that some would appreciate."
    />
    <p class="tw:text-justify tw:text-md">
      "Really, bro?" This is probably the reaction that some people would have
      when staring on this page/component. "Why this is even necessary to be a
      component?", you yelled.
    </p>
    <br />
    <p class="tw:text-justify tw:text-md">
      But, turns out, this is an extreme common pattern that you actually can
      find in many places, so it's worth to be abstracted out. (eg., Alert
      component, a blog application, ...)
    </p>

    <br />
    <br />
    <br />

    <Heading
      size="h2"
      title="Example / API"
      subtitle="This tries to show all the API/Component usages."
    />
    <VersatileTabs
      settings={[
        {
          title: "4 Levels",
          type: "preview",
          demoId: "heading-6levels",
        },
        {
          title: "Only Title",
          type: "preview",
          demoId: "heading-only-title",
        },
        {
          title: "Shortcut API Style",
          type: "preview",
          demoId: "heading-shortcut-api",
        },
      ]}
      client:only="react"
    />

    <br />
    <br />

    <Heading
      size="h2"
      title="Example / Scenario"
      subtitle="This lists common real-world use cases."
    />
    <VersatileTabs
      settings={[
        {
          title: "Article",
          type: "preview",
          demoId: "heading-article",
        },
        {
          title: "Card",
          type: "preview",
          demoId: "heading-card",
        },
        {
          title: "Alert",
          type: "preview",
          demoId: "heading-alert",
        },
      ]}
      client:only="react"
    />

    <!-- ComponentPageAPI -->
  </DocPageLayout>
</BaseLayout>
