---
import { startCase } from "lodash-es";
import "@/index.css"; // according to https://ui.shadcn.com/docs/installation/astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import DocPageLayout from "@/layouts/DocPageLayout.astro";
import ComponentPageUsage from "@/components/internal/ComponentPageUsage.tsx";
import ComponentPageHero from "@/components/internal/ComponentPageHero.tsx";
import {
  Heading,
  HeadingSubtitle,
  HeadingTitle,
} from "@/components/ui/Heading/Heading";
import VersatileTabs from "@/components/internal/VersatileTabs";
import { Badge } from "~/src/components/ui/Badge/Badge";
const routeName = Astro.url.pathname.split("/").filter(Boolean).pop();
const anatomy = `<Progress/>`;
const apiLink = `https://www.radix-ui.com/primitives/docs/components/progress`;
---

<BaseLayout>
  <DocPageLayout>
    <ComponentPageHero
      apiLink={apiLink}
      title={startCase(routeName)}
      subtitle="Displays an indicator showing the completion progress of a task, typically displayed as a progress bar."
    />

    <br />

    <Heading
      size="h2"
      title="Usage"
      subtitle="How you can play this component."
    />
    <ComponentPageUsage
      demoId="progress-demo"
      anatomy={anatomy}
      client:only="react"
      preview="The `indeterminate` is the only prop we created for this component, for others, see the API doc; but most of time, you'd probably just use either `indeterminate` or `value` (see more examples on this page)"
    />
    <br />
    <br />
    <Heading
      size="h2"
      title="Example / API"
      subtitle="This tries to show all the API/Component usages."
    />
    <VersatileTabs
      settings={[
        {
          title: "Loading",
          type: "preview",
          demoId: "progress-loading",
          content: "This just feeds different number to `value` prop.",
        },
      ]}
      client:only="react"
    />
    <br />
    <br />
    <Heading
      size="h2"
      title="Example / Scenario"
      subtitle="This lists common real-world use cases."
    />
    <VersatileTabs
      settings={[
        {
          title: "Toolbar Loader",
          type: "preview",
          demoId: "progress-toolbar-loader",
          content:
            "Some design prefers to show the progress bar on the bottom of the toolbar",
        },
      ]}
      client:only="react"
    />
  </DocPageLayout>
</BaseLayout>
