---
import LightDarkSwitcher from "@/components/internal/color-scheme-control/light-dark-switcher";
import { Button } from "@/components/ui/Button/Button";
import { default as githubSVG } from "@iconify/icons-lucide/github";
import { Icon } from "@/components/ui/Icon/Icon";
import Logo from "./TemporaryLogo";
import Searchbar from "./Searchbar";
import GithubButton from "./GithubButton";
// const { default: github } = githubSVG as any;
---

<header
  class="border-grid tw:sticky tw:top-0 tw:z-50 tw:w-full tw:border-b tw:bg-background/95 tw:backdrop-blur tw:supports-[backdrop-filter]:bg-background/60"
>
  <div class="container-wrapper">
    <div class="container tw:flex tw:h-14 tw:w-full">
      <div
        class="tw:flex tw:flex-1 tw:items-center tw:justify-between tw:gap-2 tw:md:justify-end"
      >
        <a href="/" class="tw:mr-4 tw:flex tw:items-center tw:gap-2 tw:lg:mr-6">
          <!-- <Logo className="tw:h-6 tw:w-6" /> -->
          <span class="tw:font-bold tw:inline-block"> keypointer/ui </span>
        </a>

        <nav class="tw:flex tw:items-center tw:gap-4 tw:text-sm tw:xl:gap-6">
          <a
            href="/docs/getting-started/introduction"
            class="tw:transition-colors tw:hover:text-foreground/80"
          >
            Docs
          </a>
        </nav>

        <div
          class="tw:flex tw:flex-1 tw:items-center tw:justify-between tw:gap-2 tw:md:justify-end"
        >
          <Searchbar className="tw:flex-none" client:only="react" />

          <nav class="tw:flex tw:items-center tw:gap-0.5">
            <GithubButton client:only="react" />
            <LightDarkSwitcher client:only="react" />
          </nav>
        </div>
        {
          /* <!-- TBD: Use astro-icon to add my brand icon from src/icons/keypointer-ui.svg --> */
        }
      </div>
    </div>
  </div>
</header>
